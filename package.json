{
  "name": "prompt-refine-skill",
  "version": "2.3.0",
  "description": "A model-aware Agent Skill that silently refines your prompt for the model currently answering.",
  "scripts": {
    "test": "node --test scripts/*.test.mjs && python -m unittest eval/test_run_eval.py",
    "validate": "node scripts/validate-strategies.mjs && node scripts/render-strategy-tables.mjs && node scripts/check-readme-anchors.mjs && node scripts/check-strategy-budget.mjs && node scripts/check-links.mjs --live",
    "render:tables": "node scripts/render-strategy-tables.mjs --write",
    "check:tables": "node scripts/render-strategy-tables.mjs",
    "pack:dry": "npm pack --dry-run --json"
  },
  "keywords": [
    "agent-skill",
    "agent-skills",
    "prompt-engineering",
    "prompt-refine",
    "ai-tools",
    "llm",
    "claude",
    "gpt"
  ],
  "homepage": "https://github.com/Li-Bailiang/prompt-refine-skill#readme",
  "bugs": {
    "url": "https://github.com/Li-Bailiang/prompt-refine-skill/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Li-Bailiang/prompt-refine-skill.git"
  },
  "license": "MIT",
  "author": "Li-Bailiang",
  "files": [
    "SKILL.md",
    "data/",
    "scripts/",
    "strategies/",
    "examples/",
    "hooks/",
    "README.md",
    "README.en.md",
    "README.zh.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
